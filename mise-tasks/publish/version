#!/usr/bin/env bash
#MISE description="Calculate the Spatial K publish version"

set -euo pipefail

ref_type="${GITHUB_REF_TYPE:-}"
ref_name="${GITHUB_REF_NAME:-}"

if [ -z "$ref_type" ] || [ -z "$ref_name" ]; then
  if ref_name="$(git symbolic-ref --quiet --short HEAD)"; then
    ref_type="branch"
  else
    ref_name="$(git describe --exact-match --tags HEAD 2>/dev/null || true)"
    if [ -n "$ref_name" ]; then
      ref_type="tag"
    fi
  fi
fi

latest_release_version() {
  if git remote get-url origin >/dev/null 2>&1; then
    git ls-remote --tags --refs origin "v*" |
      awk '{print $2}' |
      sed "s#^refs/tags/##"
  else
    git tag --list "v*"
  fi |
    sed -nE "s/^v([0-9]+)\.([0-9]+)\.([0-9]+)$/\1.\2.\3/p" |
    sort -V |
    tail -n 1
}

case "$ref_type:$ref_name" in
  tag:v*)
    if [[ ! "$ref_name" =~ ^v[0-9]+\.[0-9]+\.[0-9]+(-[0-9A-Za-z][0-9A-Za-z.-]*)?$ ]]; then
      echo "Unsupported release tag: $ref_name" >&2
      exit 1
    fi
    echo "${ref_name#v}"
    ;;
  branch:main)
    latest="$(latest_release_version)"
    if [ -z "$latest" ]; then
      echo "No vX.Y.Z release tag is reachable from HEAD" >&2
      exit 1
    fi
    IFS=. read -r major minor patch <<< "$latest"
    echo "${major}.$((minor + 1)).0-SNAPSHOT"
    ;;
  *)
    echo "Publishing is only supported from main or vX.Y.Z tags; got ${ref_type:-unknown}:${ref_name:-unknown}" >&2
    exit 1
    ;;
esac
